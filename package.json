{
  "name": "tournament-tracker",
  "version": "2.0.0",
  "private": true,
  "workspaces": [
    "Frontend",
    "Backend"
  ],
  "scripts": {
    "dev": "npm-run-all --parallel dev:server dev:client",
    "dev:server": "npm --workspace Backend run dev",
    "dev:client": "npm --workspace Frontend run dev",
    "start": "npm --workspace Backend run start",
    "build": "npm --workspace Frontend run build"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5"
  },
  "dependencies": {
    "bcrypt": "^6.0.0",
    "dotenv": "^17.3.1",
    "pg": "^8.20.0"
  }
}
